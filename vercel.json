{
  "version": 2,
  "buildCommand": "mkdir -p dist && cp *.html *.css *.js dist/ 2>/dev/null || true",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
